# Postgres
POSTGRES_USER=multistrat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=multistrat

# pgAdmin (web UI: http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Connection strings (for apps and Alembic)
DATABASE_URL=postgresql://multistrat:changeme@localhost:5432/multistrat

# Strategy pipelines (Phase 1 daily); defaults to DATABASE_URL if unset
STRATEGIES_PIPELINE_DATABASE_URL=
REDIS_URL=redis://localhost:6379

# Market data service (optional overrides; isolated from OMS — see .cursor/rules/env-and-config.mdc)
MARKET_DATA_DATABASE_URL=postgresql://multistrat:changeme@localhost:5432/multistrat
MARKET_DATA_BINANCE_BASE_URL=https://api.binance.com
MARKET_DATA_BINANCE_PERPS_BASE_URL=https://fapi.binance.com
MARKET_DATA_CMC_API_KEY=

# Binance (testnet for dev; RUN_BINANCE_TESTNET=1 enables testnet integration tests)
RUN_BINANCE_TESTNET=0
BINANCE_TESTNET=false
BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=

# PMS asset price feed (source/coins in pms/config.py constants)
BINANCE_PRICE_FEED_BASE_URL=https://api.binance.com
