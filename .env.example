# Postgres
POSTGRES_USER=multistrat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=multistrat

# pgAdmin (web UI: http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Connection strings (for apps and Alembic)
DATABASE_URL=postgresql://multistrat:changeme@localhost:5432/multistrat
REDIS_URL=redis://localhost:6379

# Binance (testnet for dev; set RUN_BINANCE_TESTNET=1 to run testnet integration tests)
BINANCE_TESTNET=true
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Fills listener: wsapi (default, method-based) or listenkey (classic stream)
# BINANCE_FILLS_STREAM=wsapi
